{
  "openmcp": "1.0.0",
  "info": {
    "title": "Minimal Valid API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.example.com"
    }
  ],
  "tools": {
    "echo": {
      "description": "Echo input back",
      "input": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "maxLength": 100 }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "response": { "type": "string", "maxLength": 100 }
        }
      }
    }
  }
}
